{
  "manifest_version": 3,
  "name": "Tumblr Dashboard Bookmark Highlighter",
  "version": "1.1.0",
  "description": "An extension to make Tumblr's 'last read here' bookmark more visible with a glowing gold marker.",
  "browser_specific_settings": {
    "gecko": {
      "id": "tumblr-lastread-highlighter@galli.local",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.tumblr.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
