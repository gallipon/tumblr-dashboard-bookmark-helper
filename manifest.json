{
  "manifest_version": 3,
  "name": "Tumblr Dashboard Bookmark Helper",
  "version": "1.2.0",
  "description": "Highlights Tumblr's 'last read here' bookmark with a glowing marker and helps you jump to it instantly.",
  "browser_specific_settings": {
    "gecko": {
      "id": "tumblr-bookmark-helper@galli.local",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["storage"],
  "options_ui": {
    "page": "options.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.tumblr.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
